# VALUS environment variables
# Copy to .env for local dev (Flask reads it via python-dotenv on app start),
# or set them in Vercel project settings for production deployment.

# ── Flask session signing ────────────────────────────────────────────
# Used to sign the cookie session that holds the OAuth identity claims.
# Generate with:  python3 -c "import secrets; print(secrets.token_hex(48))"
# Required for any auth flow.  If absent, sign-in is disabled site-wide
# (the app still serves the analyze / discover / portfolio flows).
SECRET_KEY=

# ── Google OAuth (one-tap sign-in) ───────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials → "OAuth 2.0
# Client IDs" → Web application.  Authorised redirect URI:
#   http://127.0.0.1:5050/auth/callback     (local)
#   https://<your-domain>/auth/callback     (production)
# When absent, the sign-in modal explains that auth is not configured
# and the leaderboard/portfolio fall back to localStorage-only mode.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Vercel KV (persistent leaderboard) ───────────────────────────────
# Provision via Vercel dashboard → Storage → KV.  Vercel auto-injects
# this on production.  For local dev, paste the rediss://... URL from
# the KV detail page.  When absent, we fall back to /tmp + in-memory
# (per-instance, so works locally but not durable on serverless).
KV_URL=

# ── Claude Haiku (per-ticker Lynch verdict + ambiguous-headline tie-break)
# Set to your Anthropic API key (sk-ant-…).  When present, every analyzed
# ticker gets a Peter-Lynch-flavored verdict block (Buy/Hold/Watch/Avoid,
# bull/bear case, sovereign-backstop awareness) generated by claude-haiku-
# 4-5-20251001 and rendered in the "Lynch Lens" card on the analysis page.
# Costs are negligible (~$0.001 / ticker, 24h cached).  When absent the
# Lynch card is hidden and the rest of the app works unchanged.
ANTHROPIC_API_KEY=

# ── Stripe (VALUS+ $2/month subscription) ───────────────────────────
# Get from https://dashboard.stripe.com/
#   - STRIPE_SECRET_KEY:   sk_live_... (production) or sk_test_... (sandbox)
#   - STRIPE_PRICE_ID:     price_...   The recurring $2/month price object.
#                          Create in Stripe Dashboard → Products → "VALUS+",
#                          $2.00 USD, monthly recurring.
#   - STRIPE_WEBHOOK_SECRET: whsec_... From Stripe Dashboard → Developers →
#                          Webhooks → endpoint pointing at /api/stripe/webhook,
#                          subscribed to checkout.session.completed,
#                          customer.subscription.updated,
#                          customer.subscription.deleted.
# Public Stripe Checkout success/cancel URLs are derived from the request
# origin so they "just work" locally and in prod.  When these vars are
# absent, the Upgrade button is hidden and the app runs entirely free-tier.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# DEV ONLY. The /api/stripe/webhook endpoint fails CLOSED: when
# STRIPE_WEBHOOK_SECRET is unset it rejects every webhook with 503 so a
# forged "checkout.session.completed" can't grant a free subscription.
# Set STRIPE_WEBHOOK_ALLOW_UNSIGNED=1 to skip signature verification for
# local testing only — it is ignored on Vercel (VERCEL env present) and
# must NEVER be set in production.
STRIPE_WEBHOOK_ALLOW_UNSIGNED=

# Comma-separated list of email addresses that get treated as VALUS+ without
# a real Stripe subscription.  Useful for ops grants, comp accounts, or
# QA before Stripe is live.  Each email is lowercased and exact-matched
# against session.user.email.  Leave empty in production.
VALUS_PLUS_EMAILS=

# ── Congressional STOCK Act feeds (House + Senate PTRs) ──────────────
# Free community JSON mirrors of House Clerk and Senate eFD Periodic
# Transaction Reports.  Override only if the default S3 buckets move.
# Cached server-side for 6 hours.  Powers the "Congressional trades"
# card on the ticker page.
STOCK_WATCHER_HOUSE_URL=
STOCK_WATCHER_SENATE_URL=
