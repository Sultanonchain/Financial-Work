{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python", "config": { "maxLambdaSize": "15mb", "maxDuration": 60 } },
    { "src": "static/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)",        "dest": "/app.py" }
  ],
  "crons": [
    { "path": "/api/cron/refresh-heatmap", "schedule": "0 * * * *" }
  ]
}
